{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "xBrowserAI Environment Schema",
  "type": "object",
  "properties": {
    "X_ANTHROPIC_API_KEY": { "type": "string", "minLength": 1 },
    "X_GOOGLE_API_KEY": { "type": "string" },
    "X_OPENAI_API_KEY": { "type": "string" },

    "PORT": { "type": "string", "pattern": "^[0-9]+$" },
    "HOST": { "type": "string" },
    "LOG_LEVEL": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"]
    },

    "ANTHROPIC_MODEL": { "type": "string" },
    "ANTHROPIC_MODEL_FAST": { "type": "string" },

    "X_WORKSPACE": { "type": "string" },
    "X_SYSTEM_PROMPT": { "type": "string" },
    "X_TEMP": { "type": "string", "pattern": "^[0-9.]+$" },
    "X_MAX_TOKENS": { "type": "string", "pattern": "^[0-9]+$" },

    "CF_ACCOUNT_ID": { "type": "string" },
    "CF_API_TOKEN": { "type": "string" },

    "CF_R2_BUCKET": { "type": "string" },
    "CF_R2_ACCESS_KEY_ID": { "type": "string" },
    "CF_R2_SECRET_ACCESS_KEY": { "type": "string" },

    "CF_QUEUE_NAME": { "type": "string" },
    "CF_QUEUE_CONSUMER": { "type": "string" },

    "WORKER_CONCURRENCY": { "type": "string", "pattern": "^[0-9]+$" },
    "WORKER_MAX_PAYLOAD": { "type": "string", "pattern": "^[0-9]+$" },

    "VITE_AI_ENDPOINT": { "type": "string" },
    "X_BRAND_TOKEN": { "type": "string" }
  },
  "required": [
    "X_ANTHROPIC_API_KEY",
    "PORT",
    "HOST",
    "LOG_LEVEL",
    "ANTHROPIC_MODEL",
    "X_SYSTEM_PROMPT",
    "VITE_AI_ENDPOINT"
  ],
  "additionalProperties": false
}
